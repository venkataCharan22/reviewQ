# Path to your Firebase Admin service account JSON.
# Default: ./secrets/firebase-admin.json (auto-loaded if present, no env var needed)
# Override only if you store it elsewhere.
# FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-admin.json

# Alternative: paste the full JSON inline (useful for Vercel/serverless deploys).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
